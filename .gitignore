# Secrets — never commit (CLAUDE.md "Things to never do silently").
.env

# Python build / cache
__pycache__/
*.pyc
*.egg-info/
.venv/
dist/
build/

# Tool caches
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Test coverage
htmlcov/
.coverage

# Tailwind: only the source CSS is committed; the hashed build output is generated
# at image build time by the tailwind-builder stage of the Dockerfile.
app/static/css/tailwind.*.css
!app/static/css/tailwind.src.css
