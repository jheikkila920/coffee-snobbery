# Snobbery — environment variable inventory.
#
# Procedure: `cp .env.example .env`, then fill in the secrets per the
# generation hints below. `.env` is gitignored; this file is committed.
#
# Every variable here corresponds to a field on the `Settings` class in
# `app/config.py` — `tests/test_env_example.py` enforces parity.
# Adding a new env var? Follow the 4-step procedure in CLAUDE.md.

# --- Postgres ---
# default: snobbery — operator can pick anything for their household
POSTGRES_USER=snobbery
# generate: openssl rand -hex 32
POSTGRES_PASSWORD=
# default: snobbery — must match the database name in DATABASE_URL below
POSTGRES_DB=snobbery
# Composed from POSTGRES_* above; coffee-snobbery-db is the compose service name.
DATABASE_URL=postgresql+psycopg://snobbery:CHANGE_ME@coffee-snobbery-db:5432/snobbery

# --- App secrets ---
# generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=

# generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Comma-separated list (first = primary for encryption, all attempted for decryption). Phase 3 wires the MultiFernet construction.
APP_ENCRYPTION_KEY=

# --- Proxy / runtime ---
# Comma-separated list of upstream IPs uvicorn will trust for X-Forwarded-*
# headers. Defaults:
#   - NGINX on the same VPS as Docker (host-port-bind topology): 127.0.0.1
#   - Nginx Proxy Manager (NPM) on the shared docker network: *
# The NPM container's IP is allocated by Docker and can change; * is the
# documented setting (project memory: snobbery-vps-npm-reverse-proxy).
# Setting this wrong breaks Secure cookies — see README "Reverse proxy".
TRUSTED_PROXY_IPS=127.0.0.1
# IANA name; consumed by APScheduler (Phase 8)
APP_TIMEZONE=America/Chicago
# consumed by Phase 8 backup job
BACKUP_RETENTION_DAYS=14

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# json (default) | console
LOG_FORMAT=json
